{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-v1/glm4:9b",
  "small_model": "local-v1/glm4:9b",
  "server": {
    "port": 9506,
    "hostname": "127.0.0.1",
    "mdns": false
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "python *": "ask",
      "rm *": "deny",
      "git push *": "deny"
    }
  },
  "agent": {
    "build": {
      "permission": {
        "edit": "allow",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "python *": "ask",
          "rm *": "deny"
        }
      }
    },
    "iteration": {
      "permission": {
        "edit": "allow",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "python *": "ask",
          "rm *": "deny"
        }
      }
    }
  },
  "provider": {
    "local-v1": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local OpenAI-Compatible",
      "options": {
        "baseURL": "http://172.24.16.1:11434/v1",
        "apiKey": "local"
      },
      "models": {
        "glm4:9b": {
          "name": "glm4:9b",
          "tools": false,
          "capabilities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM Local",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "local"
      },
      "models": {
        "qwen:max": {
          "name": "Qwen Max",
          "tools": true,
          "capabilities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}