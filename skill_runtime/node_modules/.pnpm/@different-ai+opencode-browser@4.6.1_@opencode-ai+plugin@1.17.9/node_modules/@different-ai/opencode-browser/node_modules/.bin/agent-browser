#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir//bin/sh" ]; then
  exec "$basedir//bin/sh"  "$basedir/../../../../../../agent-browser@0.4.4/node_modules/agent-browser/bin/agent-browser" "$@"
else
  exec /bin/sh  "$basedir/../../../../../../agent-browser@0.4.4/node_modules/agent-browser/bin/agent-browser" "$@"
fi
