# Skill Growth Studio 环境变量示例
# 复制本文件为 .env 并根据实际环境修改。

# ---------------------------------------------------------------------------
# 应用服务
# ---------------------------------------------------------------------------
# SKILL_GROWTH_PORT=3000

# ---------------------------------------------------------------------------
# 默认模型配置
# ---------------------------------------------------------------------------
# 格式：<provider-id>/<model-id>
# provider-id 需要与 opencode.json 中的 provider 键名一致。
# SKILL_GROWTH_DEFAULT_MODEL=local-v1/glm4:9b
# SKILL_GROWTH_SMALL_MODEL=local-v1/glm4:9b

# ---------------------------------------------------------------------------
# 本地 local-v1 provider 端点
# ---------------------------------------------------------------------------
# 覆盖 configs/model-providers/local-v1.yaml 中的 endpoint。
# SKILL_GROWTH_LOCAL_V1_URL=http://172.24.16.1:11434/v1

# ---------------------------------------------------------------------------
# 自定义 Provider 文件
# ---------------------------------------------------------------------------
# 指向一个 YAML/JSON 文件，用于向 opencode.json 注入额外 provider。
# SKILL_GROWTH_PROVIDERS_CONFIG=./configs/model-providers/custom.yaml

# ---------------------------------------------------------------------------
# 模型服务鉴权
# ---------------------------------------------------------------------------
# DeepSeek API（可选；设置后会注入 deepseek provider）
# DEEPSEEK_API_KEY=sk-xxxxxxxx

# OpenAI / vLLM / 其他 OpenAI-compatible 服务（在 custom.yaml 中引用）
# OPENAI_API_KEY=sk-xxxxxxxx

# ---------------------------------------------------------------------------
# Prompt Recommender 模型端点
# ---------------------------------------------------------------------------
# 默认读取 configs/model-providers/local-v1.yaml，可通过以下变量覆盖。
# SKILL_GROWTH_RECOMMENDER_URL=http://172.24.16.1:11434/v1
# SKILL_GROWTH_RECOMMENDER_API_KEY=local
# SKILL_GROWTH_RECOMMENDER_MODEL=glm4:9b

# ---------------------------------------------------------------------------
# OpenCode Web Runtime 认证
# ---------------------------------------------------------------------------
# 启动每个 stage 的 opencode web/serve 时使用的 Basic Auth 凭据。
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=skillgrowth

# ---------------------------------------------------------------------------
# bwrap 隔离（默认启用）
# ---------------------------------------------------------------------------
# 设置为 0 关闭 bubblewrap 沙箱隔离（如果未安装 bwrap 或不需要）。
# STAGE_USE_BWRAP=0
# BWRAP_DEBUG=1   # 启用 bwrap 命令调试日志

# ---------------------------------------------------------------------------
# OpenCode Web UI 反向代理（实验性）
# ---------------------------------------------------------------------------
# 默认关闭。官方未保证反向代理/UI 嵌入可用，建议通过 open_url_with_auth 新标签页打开。
# STAGE_ENABLE_PROXY=1
